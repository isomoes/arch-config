# Kookeey SOCKS5 upstream for the kookeey-bridge stack (passed to gost as -F).
#
# Copy this file to .env (which is gitignored) and fill in your real values:
#
#   cp .env.example .env && $EDITOR .env
#
# Format — PORT is the gateway port Kookeey assigned you (the local proxy port
# is fixed at 10011 in compose.yaml; this PORT is the remote SOCKS5 port):
#   socks5://USERNAME:PASSWORD@gate.kookeey.info:PORT
KOOKEEY_UPSTREAM=socks5://USERNAME:PASSWORD@gate.kookeey.info:PORT
