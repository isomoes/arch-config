# Deployment values for the frpc stack (passed to the container, read by
# frpc.toml as {{ .Envs.FRP_* }}).
#
# Copy this file to .env (gitignored via compose/**/.env) and fill in your real
# frps server details:
#
#   cp .env.example .env && $EDITOR .env

# Public address of your frps server (the box with a public IP running frps).
FRP_SERVER_ADDR=frp.example.com
# frps bind port (frps' serverPort / bindPort). Optional; defaults to 7000.
FRP_SERVER_PORT=7000
# Shared auth token — must equal auth.token in the frps config. Keep it secret.
FRP_TOKEN=replace-with-your-frps-token
# Port the frps server opens that forwards to this host's SSH. Connect with:
#   ssh -p <FRP_SSH_REMOTE_PORT> <user>@<FRP_SERVER_ADDR>
FRP_SSH_REMOTE_PORT=6000
