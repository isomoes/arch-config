[user]
	email = jiahaoxiang2000@gmail.com
	name = isomoes
[core]
	editor = nvim
[commit]
	template = ~/.config/git/commit_template.txt
[init]
	defaultBranch = main
[diff]
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[merge]
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait $MERGED
[difftool]
	prompt = false
[mergetool]
	prompt = false
	keepBackup = false
# GitHub Dark (colorblind): additions blue, deletions orange —
# matches emacs/nvim github_dark_colorblind; lazygit inherits these.
[color "diff"]
	new = "#58a6ff"
	old = "#d47616"
	frag = "#d2a8ff"
	func = "#d2a8ff"
	meta = "#c9d1d9 bold"
	context = "#8b949e"
	commit = "#d29922"
	whitespace = "#d47616 reverse"
